# Tasks example — runtime configuration.
# Copy to .env for a real run, or `export` selectively.
# Every variable below is OPTIONAL — defaults are baked in.

# Server
# ADDR has no default. When unset, fibermap.Run honors $PORT
# (Heroku / Cloud Run / fly.io / Railway convention) and falls back
# to :3000. Set ADDR explicitly to override both.
# ADDR=:3000
SHUTDOWN_TIMEOUT=10s
BODY_LIMIT=1048576

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PATCH,DELETE,OPTIONS

# Rate limit (per-IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_EXPIRATION=1m

# App
ENV=development
# API_BASE_URL=https://api.example.com   # uncomment → OpenAPI server entry
