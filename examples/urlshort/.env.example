# Postgres connection (composed into db.Config via envPrefix:"DB_")
DB_HOST=localhost
DB_PORT=5432
DB_USER=urlshort
DB_PASSWORD=urlshort
DB_NAME=urlshort
DB_SSLMODE=disable

# NATS JetStream
NATS_URL=nats://localhost:4222

# MicroLink upstream (apimap resolves ${MICROLINK_BASE_URL} at LoadFile)
MICROLINK_BASE_URL=https://api.microlink.io

# JWT signing key — PEM-encoded Ed25519 private key.
# Generate one:
#   openssl genpkey -algorithm ED25519
AUTH_PRIVATE_KEY_PEM=

# Public base URL used to render short_url in responses
SHORT_URL_BASE=http://localhost:3000

# Server
ADDR=:3000
LOG_LEVEL=info
