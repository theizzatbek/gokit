# Postgres connection (composed into db.Config via envPrefix:"DB_")
DB_HOST=localhost
DB_PORT=5432
DB_USER=urlshort
DB_PASSWORD=urlshort
DB_NAME=urlshort
DB_SSLMODE=disable

# NATS JetStream
NATS_URL=nats://localhost:4222

# MicroLink upstream (apimap resolves ${MICROLINK_BASE_URL} at LoadFile)
MICROLINK_BASE_URL=https://api.microlink.io

# JWT signing key — PEM-encoded Ed25519 private key.
# Generate one:
#   openssl genpkey -algorithm ED25519
AUTH_PRIVATE_KEY_PEM=

# Public base URL used to render short_url in responses
SHORT_URL_BASE=http://localhost:3000

# Server
ADDR=:3000
LOG_LEVEL=info

# YAML configs live under examples/urlshort/configs/. CONFIGS_DIR
# makes the kit look there for routes.yaml, clients.yaml,
# subscribers.yaml, publishers.yaml — individual Path overrides
# below are still honoured verbatim if set.
CONFIGS_DIR=configs

# Subsystem auto-build triggers; default filenames live under
# CONFIGS_DIR.
APIMAP_ENABLED=true
NATSMAP_ENABLED=true
ROUTES_ENABLED=true

# Optional Redis-backed link cache (clients/cache typed over the
# urlshort:link: prefix). Leave empty to fall back to direct
# Postgres lookups.
REDIS_URL=redis://localhost:6379